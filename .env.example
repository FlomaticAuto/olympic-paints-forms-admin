# ─────────────────────────────────────────────────────────────────
# REPO 2 — olympic-paints-forms-admin (Next.js / Vercel)
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Project URL — safe to expose (used client-side and server-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose; RLS enforces access limits
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Service role key — NEVER expose to the browser; bypasses RLS entirely
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ── Admin auth ────────────────────────────────────────────────────
# Shared secret for the admin dashboard login page.
# Set to any strong password — this is what you type at /admin/login.
ADMIN_SECRET=change-me-to-a-strong-password

# Shared secret for API route authentication (x-admin-secret header).
# Used by curl / scripts calling POST /api/forms/create etc.
# Can be the same as ADMIN_SECRET or a separate value.
FORM_ADMIN_SECRET=change-me-to-a-strong-api-secret

# ── Public URLs ───────────────────────────────────────────────────
# Full base URL of the GitHub Pages form renderer (REPO 1).
# Used to build the public_url returned by POST /api/forms/create.
# Trailing slash optional — the code handles both.
NEXT_PUBLIC_GITHUB_PAGES_BASE_URL=https://flomaticauto.github.io/forms

# Full URL of this Vercel deployment.
# Used by GET /admin/logout to build the redirect URL.
NEXT_PUBLIC_APP_URL=https://your-admin-app.vercel.app
